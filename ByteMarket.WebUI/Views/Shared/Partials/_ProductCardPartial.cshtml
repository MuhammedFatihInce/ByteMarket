@model ByteMarket.WebUI.Models.Product.ProductListViewModel
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration

@{
    var apiBaseUrl = Configuration["ApiSettings:BaseStorageAdress"];
    string noImageUrl = "https://placehold.co/600x400?text=Resim+Yok";

    var currentImagePaths = (Model.ImagePath != null && Model.ImagePath.Any())
                            ? Model.ImagePath
                                .Select(path => $"{apiBaseUrl}{path.Replace("\\", "/")}")
                                .ToList()
                            : new List<string> { noImageUrl };
}

@Html.AntiForgeryToken()

<div class="card h-100 border product-card transition-up position-relative p-2">

    <a asp-controller="Product" asp-action="Detail" asp-route-id="@Model.Id" class="stretched-link"></a>

    <button class="wishlist-btn-group wishlist-btn bg-white border rounded-circle position-absolute" id="whishListBtn" data-productId="@Model.Id" data-isInWishlist="@Model.IsInWishlist" style="z-index: 12;">
        <i class="bi @(Model.IsInWishlist ? "bi-heart-fill text-ty-orange" : "bi-heart")"></i>
    </button>

    <div class="image-box d-flex align-items-center justify-content-center p-3" data-images="@(string.Join(",", currentImagePaths))">
        <img src="@currentImagePaths.FirstOrDefault()"
             class="img-fluid object-fit-contain h-100"
             alt="@Model.Name"
             onerror="this.src='@noImageUrl'">
    </div>

    <div class="d-flex align-items-center justify-content-center px-2 mb-2">
        <div>
            @for (int i = 0; i < currentImagePaths.Count; i++)
            {
                <span class="dot @(i == 0 ? "active" : "")"></span>
            }
        </div>
    </div>

    <div class="card-divider"></div>

    <div class="card-body p-3">
        <small class="text-ty-orange fw-semibold">
            @Model.CategoryName
        </small>
        <h6 class="card-title fw-bold text-dark mt-1 text-truncate" title="@Model.Name">
            @Model.Name
        </h6>

        <div class="mt-auto px-1 position-relative" style="z-index: 10;">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h5 class="fw-bold text-ty-orange mb-0">
                    @Model.Price.ToString("N0") <span style="font-size: 0.85rem">TL</span>
                </h5>
                <small class="text-muted fw-semibold">
                    <i class="bi bi-box-seam me-1"></i><span id="stock-@Model.Id.ToLower()">Stok: @Model.Stock</span>
                </small>
            </div>

            <button class="basket-btn-group btn btn-outline-ty-orange w-100 py-2" data-productId="@Model.Id">
                Sepete Ekle
            </button>
        </div>
    </div>
</div>