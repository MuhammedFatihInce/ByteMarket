@using Microsoft.AspNetCore.Mvc.TagHelpers
@model List<ByteMarket.WebUI.Models.CategoryViewModels.ListCategoryViewModel>
@inject IConfiguration Configuration

@{
    var apiBaseUrl = Configuration["ApiSettings:BaseStorageAdress"];
    string noImageUrl = "https://placehold.co/600x400?text=Resim+Yok";
}


<header class="border-bottom shadow-sm sticky-top bg-white">
    <div class="bg-light py-1 border-bottom d-none d-lg-block">
        <div class="container d-flex justify-content-end gap-3" style="font-size: 12px;">
            <a href="#" class="text-secondary text-decoration-none">İndirim Kuponlarım</a>
            <a href="#" class="text-secondary text-decoration-none">ByteMarket'de Satış Yap</a>
            <a href="#" class="text-secondary text-decoration-none">Yardım & Destek</a>
        </div>
    </div>

    <div class="container py-3">
        <div class="row align-items-center">
            <div class="col-lg-2 col-md-3 col-6">
                <a class="navbar-brand fw-bold fs-2 text-dark" asp-area="" asp-controller="Home" asp-action="Index" style="letter-spacing: -1px;">
                    ByteMarket<span class="text-ty-orange">.</span>
                </a>
            </div>

            <div class="col-lg-6 col-md-5 d-none d-md-block">
                <div class="input-group">
                    <input type="text" class="form-control border-end-0 bg-light" placeholder="Aradığınız ürün, kategori veya markayı yazınız" style="padding: 10px 15px;">
                    <span class="input-group-text bg-light border-start-0 text-ty-orange">
                        <i class="bi bi-search fw-bold"></i>
                    </span>
                </div>
            </div>

            <div class="col-lg-4 col-md-4 col-6">
                <div class="d-flex justify-content-end align-items-center gap-4">
                    <div class="dropdown">
                        <div class="d-flex align-items-center gap-1 cursor-pointer dropdown-toggle" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person fs-4"></i>
                            <span class="d-none d-lg-inline fw-semibold small">Giriş Yap</span>
                        </div>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-3" aria-labelledby="userMenu" style="min-width: 200px;">
                            <li><h6 class="dropdown-header">Üye İşlemleri</h6></li>
                            <li><a class="dropdown-item py-2" href="#"><i class="bi bi-person-fill me-2"></i>Giriş Yap</a></li>
                            <li><a class="dropdown-item py-2" href="#"><i class="bi bi-person-plus-fill me-2"></i>Üye Ol</a></li>

                            <li><hr class="dropdown-divider"></li>

                            <li><h6 class="dropdown-header text-ty-orange fw-bold">Yönetici Paneli</h6></li>
                            <li>
                                <a class="dropdown-item py-2 fw-semibold text-danger" asp-controller="Product" asp-action="AdminIndex">
                                    <i class="bi bi-grid-fill me-2"></i>Ürün Yönetimi
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item py-2" asp-controller="Category" asp-action="AdminIndex">
                                    <i class="bi bi-tags-fill me-2"></i>Kategori Yönetimi
                                </a>
                            </li>
                        </ul>
                    </div>

                    <div class="d-flex align-items-center gap-1 cursor-pointer">
                        <i class="bi bi-heart fs-4"></i>
                        <span class="d-none d-lg-inline fw-semibold small">Favorilerim</span>
                    </div>

                    <div class="d-flex align-items-center gap-1 cursor-pointer text-ty-orange">
                        <i class="bi bi-cart3 fs-4"></i>
                        <span class="d-none d-lg-inline fw-semibold small">Sepetim</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>

<nav class="container d-none d-lg-block">
    <ul class="nav justify-content-center gap-2 category-nav-list">
        @foreach (var category in Model)
        {
            string currentImagePath = noImageUrl; 
            if (!string.IsNullOrEmpty(category.ImagePath))
            {
                var sanitizedPath = category.ImagePath.Replace("\\", "/");
                currentImagePath = $"{apiBaseUrl}{sanitizedPath}";
            }

            <li class="nav-item">
                <a asp-controller="Home" 
                   asp-action="Index" 
                   asp-route-categoryId="@category.Id"
                   class="category-item-link @(Context.Request.Query["categoryId"] == category.Id.ToString() ? "active" : "")">
                    
                    <div class="category-img-wrapper">
                        @if (!string.IsNullOrEmpty(category.ImagePath))
                        {
                            <img src="@currentImagePath" alt="@category.Name" loading="lazy">
                        }
                        else
                        {
                            <div class="text-muted d-flex align-items-center justify-content-center h-100">
                                <i class="bi bi-tag" style="font-size: 24px;"></i>
                            </div>
                        }
                    </div>

                    <span class="category-name">@category.Name</span>
                </a>
            </li>
        }
    </ul>
</nav>
