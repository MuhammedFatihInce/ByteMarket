@using ByteMarket.WebUI.Constants
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService


<header class="border-bottom shadow-sm sticky-top bg-white">
    <div class="bg-light py-1 border-bottom d-none d-lg-block">
        <div class="container d-flex justify-content-end gap-3" style="font-size: 12px;">
            <a href="#" class="text-secondary text-decoration-none">İndirim Kuponlarım</a>
            <a href="#" class="text-secondary text-decoration-none">ByteMarket'de Satış Yap</a>
            <a href="#" class="text-secondary text-decoration-none">Yardım & Destek</a>
        </div>
    </div>

    <div class="container py-3">
        <div class="row align-items-center">
            <div class="col-lg-2 col-md-3 col-6">
                <a class="navbar-brand fw-bold fs-2 text-dark" asp-area="" asp-controller="Home" asp-action="Index" style="letter-spacing: -1px;">
                    ByteMarket<span class="text-ty-orange">.</span>
                </a>
            </div>

            <div class="col-lg-6 col-md-5 d-none d-md-block">
                <div class="input-group">
                    <input type="text" class="form-control border-end-0 bg-light" placeholder="Aradığınız ürün, kategori veya markayı yazınız" style="padding: 10px 15px;">
                    <span class="input-group-text bg-light border-start-0 text-ty-orange">
                        <i class="bi bi-search fw-bold"></i>
                    </span>
                </div>
            </div>

            <div class="col-lg-4 col-md-4 col-6">
                <div class="d-flex justify-content-end align-items-center gap-4">

                    <div class="dropdown">
                        <div class="d-flex align-items-center gap-2 cursor-pointer dropdown-toggle no-caret" id="userMenu" data-bs-toggle="dropdown">
                            <i class="bi bi-person fs-4"></i>
                            <div class="user-text-wrapper d-none d-lg-flex flex-column">
                                <span class="small text-muted lh-1">@(User.Identity.IsAuthenticated ? "Hesabım" : "Merhaba,")</span>
                                <span class="fw-bold small">@(User.Identity.IsAuthenticated ? User.Identity.Name : "Giriş Yap")</span>
                            </div>
                        </div>

                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-5 animate slideIn" aria-labelledby="userMenu">
                            @if (User.Identity.IsAuthenticated)
                            {
                                <li><h6 class="dropdown-header">Üye Bilgileri</h6></li>
                                <li><a class="dropdown-item py-2" href="#"><i class="bi bi-person-circle me-2"></i>Profilim</a></li>
                                <li><a class="dropdown-item py-2" href="#"><i class="bi bi-box-seam me-2"></i>Siparişlerim</a></li>
                                @if ((await AuthorizationService.AuthorizeAsync(User, AuthorizePolicies.AdminOnly)).Succeeded)
                                {
                                    <li><hr class="dropdown-divider"></li>
                                    <li><h6 class="dropdown-header text-ty-orange">Yönetim</h6></li>
                                    <li>
                                        <a class="dropdown-item py-2 fw-semibold text-danger" asp-controller="Product" asp-action="AdminIndex">
                                            <i class="bi bi-grid-fill me-2"></i>Ürün Yönetimi
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2" asp-controller="Category" asp-action="AdminIndex">
                                            <i class="bi bi-tags-fill me-2"></i>Kategori Yönetimi
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2 fw-semibold text-dark" asp-controller="Role" asp-action="Index">
                                            <i class="bi bi-shield-lock-fill me-2 text-primary"></i>Rol Yönetimi
                                        </a>
                                    </li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 text-danger fw-bold" asp-controller="Account" asp-action="Logout"><i class="bi bi-door-open me-2"></i>Çıkış Yap</a></li>
                            }
                            else
                            {
                                <li class="p-3">
                                    <a class="btn btn-primary w-100 bg-ty-orange border-0 fw-bold mb-2" asp-controller="Account" asp-action="Login"><i class="bi bi-person-fill me-2"></i>Giriş Yap</a>
                                    <a class="btn btn-outline-secondary w-100 fw-bold" asp-controller="Account" asp-action="Register"><i class="bi bi-person-plus-fill me-2"></i>Üye Ol</a>
                                </li>
                            }
                        </ul>
                    </div>

                    <div class="d-flex align-items-center gap-1 cursor-pointer">
                        <i class="bi bi-heart fs-4"></i>
                        <span class="d-none d-lg-inline fw-semibold small">Favorilerim</span>
                    </div>

                    <div class="d-flex align-items-center gap-1 cursor-pointer text-ty-orange">
                        <i class="bi bi-cart3 fs-4"></i>
                        <span class="d-none d-lg-inline fw-semibold small">Sepetim</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>


