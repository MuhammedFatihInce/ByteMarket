@using ByteMarket.WebUI.Models.ProductViewModels
@model List<ProductListViewModel>

<div class="container-fluid pt-4 px-4">
    <div class="row g-4">
        <div class="col-12">
            <div class="bg-white rounded shadow-sm p-4">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div>
                        <h5 class="mb-0 fw-bold text-dark">Ürün Yönetimi</h5>
                        <small class="text-muted">Mağazanızdaki tüm ürünleri buradan yönetebilirsiniz.</small>
                    </div>
                    <a asp-action="Create" class="btn btn-ty-orange text-white shadow-sm fw-bold px-4 py-2">
                        <i class="bi bi-plus-circle me-2"></i>YENİ ÜRÜN EKLE
                    </a>
                </div>

                <div class="table-responsive">
                    <table class="table text-start align-middle table-hover mb-0 border-top">
                        <thead>
                            <tr class="text-secondary small text-uppercase" style="background-color: #fafafa;">
                                <th scope="col" class="py-3 ps-3">Ürün Bilgisi</th>
                                <th scope="col" class="py-3">Birim Fiyat</th>
                                <th scope="col" class="py-3">Stok Miktarı</th>
                                <th scope="col" class="py-3">Durum</th>
                                <th scope="col" class="py-3 text-end pe-3">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                @await Html.PartialAsync("/Views/Shared/Partials/_AdminProductRowPartial.cshtml", item)
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
            $(document).on('click', '.btn-delete', function () {
            const productId = $(this).data('id');
            const productName = $(this).data('name');

            Swal.fire({
                title: 'Emin misiniz?',
                text: `"${productName}" isimli ürün ve bağlı tüm görseller kalıcı olarak silinecek!`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ff6000', // Trendyol Turuncusu
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgeç',
                reverseButtons: true
            }).then(async (result) => {
                if (result.isConfirmed) {
                    try {
                        const response = await fetch(`https://localhost:44367/api/Products/Delete/${productId}`, {
                            method: 'DELETE'
                        });

                        if (response.ok) {
                            Swal.fire(
                                'Silindi!',
                                'Ürün başarıyla sistemden kaldırıldı.',
                                'success'
                            );

                            const row = document.getElementById(`row-${productId}`);
                            if (row) {
                                row.style.transition = "all 0.4s ease";
                                row.style.opacity = "0";
                                row.style.transform = "translateX(20px)";
                                setTimeout(() => row.remove(), 400);
                            }
                        } else {
                            Swal.fire('Hata!', 'Silme işlemi sırasında sunucu bir hata döndürdü.', 'error');
                        }
                    } catch (error) {
                        Swal.fire('Hata!', 'API bağlantısı kurulamadı.', 'error');
                    }
                }
            });
        });
    </script>
}