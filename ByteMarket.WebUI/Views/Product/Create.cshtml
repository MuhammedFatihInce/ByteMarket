@model ByteMarket.WebUI.Models.ProductViewModels.CreateProductViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h4 class="mb-0 fw-bold text-ty-orange"><i class="bi bi-box-seam me-2"></i>Yeni Ürün Listele</h4>
                </div>
                <div class="card-body p-4">

                    <form asp-action="Create" method="post">
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <input asp-for="Name" class="form-control bg-light border-0 shadow-none py-2" placeholder="Ürün adını giriniz">
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Price" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <input asp-for="Price" type="number" step="0.01" class="form-control bg-light border-0 shadow-none py-2">
                                    <span class="input-group-text bg-light border-0">₺</span>
                                </div>
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="Stock" class="form-label fw-semibold"></label>
                                <input asp-for="Stock" type="number" class="form-control bg-light border-0 shadow-none py-2">
                                <span asp-validation-for="Stock" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-grid mt-3">
                            <button type="submit" class="btn btn-primary py-2 fw-bold bg-ty-orange border-0 shadow-sm">
                                ÜRÜNÜ YAYINLA
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}