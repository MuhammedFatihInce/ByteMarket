@using System.Security.Claims
@using ByteMarket.WebUI.Models.Product
@using ByteMarket.WebUI.Models.ProductReview
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model (SingleProductViewModel Product, List<ProductReviewListViewModel> Reviews)
@inject IConfiguration Configuration
@{
    ViewData["Title"] = Model.Product.Name;
    var apiBaseUrl = Configuration["ApiSettings:BaseStorageAdress"];
    string noImageUrl = "https://placehold.co/600x400?text=Resim+Yok";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

@Html.AntiForgeryToken()

<div class="container mt-5 mb-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">ByteMarket</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Product.Categories.FirstOrDefault()?.Name</li>
        </ol>
    </nav>

    <div class="row g-5">
        <div class="col-lg-6">
            <div id="productCarousel" class="carousel slide carousel-dark border rounded-3 bg-white shadow-sm" data-bs-ride="carousel">
                <div class="carousel-inner p-4" style="height: 500px;">
                    @if (Model.Product.ProductImageFiles != null && Model.Product.ProductImageFiles.Any())
                    {
                        @for (int i = 0; i < Model.Product.ProductImageFiles.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "") h-100">
                                <div class="img-zoom-container h-100 w-100 d-flex justify-content-center">

                                    <div class="img-zoom-lens" id="lens-@i"></div>

                                    <img id="image-@i" src="@($"{apiBaseUrl}{Model.Product.ProductImageFiles[i].Path.Replace("\\", "/")}")"
                                         class="d-block w-100 h-100 object-fit-contain" alt="@Model.Product.Name">
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="carousel-item active h-100">
                            <img src="@noImageUrl" class="d-block w-100 h-100 object-fit-contain" alt="Resim Yok">
                        </div>
                    }
                </div>

                <div id="zoom-result"></div>

                <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                </button>
            </div>

            <div class="product-thumbnails d-flex flex-wrap gap-2 mt-3">
                @if (Model.Product.ProductImageFiles != null && Model.Product.ProductImageFiles.Any())
                {
                    @for (int i = 0; i < Model.Product.ProductImageFiles.Count; i++)
                    {
                        <div class="thumb-item @(i == 0 ? "active" : "")" 
                             data-bs-target="#productCarousel" 
                             data-bs-slide-to="@i">
                            <img src="@($"{apiBaseUrl}{Model.Product.ProductImageFiles[i].Path.Replace("\\", "/")}")"
                                 class="img-fluid object-fit-contain"
                                 alt="@Model.Product.Name">
                        </div>
                    }
                }
            </div>

            

        </div>

        <div class="col-lg-6">
            <div class="product-info-card p-4 border rounded-3 shadow-sm bg-white">
                <div class="mb-2">
                    @foreach (var cat in Model.Product.Categories)
                    {
                        <span class="badge bg-light text-ty-orange border me-1">@cat.Name</span>
                    }
                </div>
                <h2 class="fw-bold text-dark mb-3">@Model.Product.Name</h2>

                <div class="price-section mb-4">
                    <h3 class="fw-bold text-ty-orange mb-0">@Model.Product.Price.ToString("C2")</h3>
                    <small class="text-muted">KDV Dahil</small>
                </div>

                <div class="stock-status mb-4 p-3 bg-light rounded-3 d-flex align-items-center">
                    <i class="bi bi-box-seam fs-4 text-ty-orange me-3"></i>
                    <div>
                        <span class="fw-bold d-block">Stok Durumu</span>
                        <small id="stock-detail-@Model.Product.Id.ToLower()"  class="@(Model.Product.Stock > 0 ? "text-success" : "text-danger")">
                            @(Model.Product.Stock > 0 ? $"Şu an stokta {Model.Product.Stock} adet var!" : "Tükendi")
                        </small>
                    </div>
                </div>

                <div class="d-flex align-items-center gap-2 mt-4">
                    <button class="basket-btn-group btn btn-ty-orange flex-grow-1 text-white fw-bold py-3 shadow-sm @(Model.Product.Stock <= 0 ? "disabled" : "")" data-productId="@Model.Product.Id">
                         SEPETE EKLE
                    </button>

                    <button class="wishlist-btn-group btn wishlist-detail-btn shadow-sm rounded-circle d-flex align-items-center justify-content-center" id="whishListBtn" data-productId="@Model.Product.Id" data-isInWishList="@Model.Product.IsInWishlist">
                        <i class="bi @(Model.Product.IsInWishlist ? "bi-heart-fill text-ty-orange" : "bi-heart")"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="product-description-card card p-4 rounded-3 shadow-sm bg-white">
                <h4 class="fw-bold mb-4 border-bottom pb-3 text-dark">
                    <i class="bi bi-file-text me-2 text-ty-orange"></i>Ürün Açıklaması
                </h4>
            
                <div class="product-content" style="line-height: 1.8;">
                    @if (!string.IsNullOrEmpty(Model.Product.Description))
                    {
                    
                        @Html.Raw(Model.Product.Description)
                    }
                    else
                    {
                        <p class="text-muted italic">Bu ürün için detaylı açıklama girilmemiştir.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (User.Identity.IsAuthenticated && Model.Product.IsPurchased)
    {
        <div class="mt-5 card p-4 shadow-sm">
            <h3 class="fw-bold">Ürünü Değerlendir</h3>
            <form id="productReviewForm">
                <input type="hidden" id="productId" value="@Model.Product.Id" />

                <div class="mb-3">
                    <label class="form-label d-block">Puanınız:</label>
                    <div class="star-rating">
                        <input type="radio" name="rating" value="5" id="5"><label for="5">☆</label>
                        <input type="radio" name="rating" value="4" id="4"><label for="4">☆</label>
                        <input type="radio" name="rating" value="3" id="3"><label for="3">☆</label>
                        <input type="radio" name="rating" value="2" id="2"><label for="2">☆</label>
                        <input type="radio" name="rating" value="1" id="1"><label for="1">☆</label>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label for="comment">Yorumunuz</label>
                    <textarea class="form-control" id="comment" rows="4" placeholder="Ürün hakkındaki deneyimlerinizi paylaşın..."></textarea>
                </div>

                <button type="submit" id="btnSubmit" class="btn btn-ty-orange text-white w-100">
                    Yorumu Gönder
                </button>
            </form>
            <div id="responseMessage" class="mt-3"></div>
        </div>
    }
    

    <div class="mt-5">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h3 class="fw-bold mb-0">Ürün Yorumları (@Model.Reviews.Count)</h3>
            @if (Model.Reviews.Any())
            {
                <div class="d-flex align-items-center">
                    <span class="badge bg-ty-orange text-white fs-6 me-2">
                        @(Model.Reviews.Average(x => x.Rating).ToString("0.0")) / 5
                    </span>
                    <div class="text-warning">
                        <i class="bi bi-star-fill"></i>
                    </div>
                </div>
            }
        </div>

        <div id="reviewsList">
            @if (Model.Reviews != null && Model.Reviews.Any())
            {
                @foreach (var review in Model.Reviews)
                {
                    <div id="review-@review.Id" class="card border-0 shadow-sm mb-3">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <div class="d-flex align-items-center mb-1">
                                        <h6 class="fw-bold mb-0 me-2">@review.UserName</h6>
                                        <div class="text-warning small">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="bi @(i <= review.Rating ? "bi-star-fill" : "bi-star")"></i>
                                            }
                                        </div>
                                    </div>
                                    <small class="text-muted">
                                        <i class="bi bi-calendar3 me-1"></i> @review.CreateDate.ToString("dd MMMM yyyy")
                                    </small>
                                </div>
                                <div class="d-flex gap-2 align-items-center">
                                    @if (User.Identity.IsAuthenticated && review.UserId == currentUserId)
                                    {
                                        <div class="dropdown">
                                            <button class="btn btn-light btn-sm rounded-circle" type="button" data-bs-toggle="dropdown">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                                <li>
                                                    <a class="dropdown-item text-primary btn-edit-review" href="javascript:void(0)"
                                                       data-id="@review.Id" data-comment="@review.Comment" data-rating="@review.Rating">
                                                        <i class="bi bi-pencil-square me-2"></i> Düzenle
                                                    </a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item text-danger btn-delete-review" href="javascript:void(0)"
                                                       data-id="@review.Id">
                                                        <i class="bi bi-trash3 me-2"></i> Sil
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    }
                                </div>
                            </div>
                            <p class="card-text text-secondary mt-3" style="line-height: 1.6;">
                                @review.Comment
                            </p>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5 bg-light rounded-3 border">
                    <i class="bi bi-chat-left-text fs-1 text-muted d-block mb-3"></i>
                    <p class="text-muted fw-medium">Bu ürün için henüz yorum yapılmamış.</p>
                </div>
            }
        </div>
    </div>

</div>

<div class="modal fade" id="editReviewModal" tabindex="-1" aria-labelledby="editReviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold" id="editReviewModalLabel">Yorumu Düzenle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">

                <div id="editModelResponseMessage" class="my-3"></div>

                <form id="editReviewForm">
                    <input type="hidden" id="editReviewId" />

                    <div class="mb-3">
                        <label class="form-label d-block fw-medium">Puanınız:</label>
                        <div class="star-rating edit-stars">
                            <input type="radio" name="editRating" value="5" id="edit-5"><label for="edit-5">☆</label>
                            <input type="radio" name="editRating" value="4" id="edit-4"><label for="edit-4">☆</label>
                            <input type="radio" name="editRating" value="3" id="edit-3"><label for="edit-3">☆</label>
                            <input type="radio" name="editRating" value="2" id="edit-2"><label for="edit-2">☆</label>
                            <input type="radio" name="editRating" value="1" id="edit-1"><label for="edit-1">☆</label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="editComment" class="form-label fw-medium">Yorumunuz:</label>
                        <textarea class="form-control" id="editComment" rows="4" placeholder="Deneyiminizi güncelleyin..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Vazgeç</button>
                <button type="button" id="btnUpdateReview" class="btn btn-ty-orange text-white px-4">Değişiklikleri Kaydet</button>
            </div>
        </div>
    </div>
</div>

    


<style>
    .star-rating {
        display: flex;
        flex-direction: row-reverse;
        justify-content: flex-end;
    }

        .star-rating input {
            display: none;
        }

        .star-rating label {
            font-size: 30px;
            color: #ddd;
            cursor: pointer;
        }

        .star-rating input:checked ~ label {
            color: #f5b301;
        }

        .star-rating label:hover, .star-rating label:hover ~ label {
            color: #f5b301;
        }
</style>

@section Scripts{
    <script src="~/js/customer/product/product-detail.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            initProductDetailCarousel('productCarousel');
            imageZoom("image-0", "zoom-result", "lens-0");
        });
    </script>
    <script src="~/js/customer/wishList/wishList-add.js" asp-append-version="false"></script>
    <script src="~/js/customer/basket/basket-add.js" asp-append-version="false"></script>
    <script src="~/js/customer/stock-tracking.js" asp-append-version="false"></script>
}

