@model ByteMarket.WebUI.Models.Order.SingleOrderViewModel
@inject IConfiguration Configuration

@{
    ViewData["Title"] = "Sipariş Detayı";
    var apiBaseUrl = Configuration["ApiSettings:BaseStorageAdress"];
    string noImageUrl = "https://placehold.co/600x400?text=Resim+Yok";
}
@Html.AntiForgeryToken()

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Sipariş Detayı</h2>
            <small class="text-muted">Sipariş No: <span class="fw-bold text-dark">#@Model.OrderCode</span></small>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-dark text-white btn-sm rounded-pill px-3 btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#invoiceModal">
                <i class="fa fa-file-invoice me-1"></i> Faturayı Görüntüle
            </button>

            <a asp-action="Index" class="btn btn-outline-dark btn-sm rounded-pill px-3">
                <i class="fa fa-arrow-left me-1"></i> Siparişlerime Dön
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h5 class="mb-0 fw-bold"><i class="fa fa-shopping-bag me-2 text-ty-orange"></i>Ürünler (@Model.BasketItems.Sum(x=> x.Quantity))</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <tbody>
                                @foreach (var item in Model.BasketItems)
                                {
                                    var currentImagePath = !string.IsNullOrEmpty(item.ImagePath)
                                    ? $"{apiBaseUrl}{item.ImagePath.Replace("\\", "/")}"
                                    : noImageUrl;

                                    <tr>
                                        <td class="ps-4 py-3" style="width: 100px;">
                                            <div class="rounded border p-1" style="width: 80px; height: 80px;">
                                                <img src="@currentImagePath" class="img-fluid object-fit-contain h-100 w-100"
                                                     alt="@item.Name" onerror="this.src='@noImageUrl'">
                                            </div>
                                        </td>
                                        <td>
                                            <h6 class="mb-1 fw-bold text-dark">@item.Name</h6>
                                            <small class="text-muted">Adet: @item.Quantity</small>
                                        </td>
                                        <td class="text-end pe-4">
                                            <span class="fw-bold text-ty-orange">@((item.Price * item.Quantity).ToString("C2"))</span>
                                            <br />
                                            <small class="text-muted" style="font-size: 0.7rem;">Birim: @item.Price.ToString("C2")</small>
                                        </td>
                                        <td class="text-end pe-4">
                                            @if (!item.IsReviewed)
                                            {
                                                <button type="button" class="btn btn-outline-ty-orange btn-sm rounded-pill"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#productReviewModal"
                                                        data-bs-order-id="@Model.Id"
                                                        data-bs-product-id="@item.Id"
                                                        data-bs-product-name="@item.Name"
                                                        data-bs-product-image="@currentImagePath">
                                                    <i class="fa fa-edit me-1"></i> Ürünü Değerlendir
                                                </button>
                                            }
                                            else
                                            {
                                                <div class="d-flex flex-column align-items-end" style="gap:6px">
                                                    <button type="button" class="btn btn-outline-dark btn-sm rounded-pill fw-bold px-3"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#editReviewModal"
                                                            data-bs-product-name="@item.Name"
                                                            data-bs-product-image="@currentImagePath"
                                                            data-bs-product-review-id="@item.ReviewId"
                                                            data-bs-product-comment="@item.Comment"
                                                            data-bs-product-rating="@item.Rating">
                                                        <i class="fa fa-cog me-1"></i> Değerlendirmeyi Düzenle
                                                    </button>
                                                    <button type="button" id="btnDeleteReview" class="btn btn-outline-danger btn-sm rounded-pill fw-bold px-3"
                                                        data-review-id="@item.ReviewId">
                                                        <i class="fa fa-trash-alt me-1"></i> Değerlendirmeyi Sil
                                                    </button>
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3 border-bottom pb-2"><i class="fa fa-map-marker-alt me-2 text-ty-orange"></i>Teslimat Bilgileri</h6>
                    <p class="small text-dark mb-1 fw-bold">Teslimat Adresi:</p>
                    <p class="small text-muted mb-3">@Model.Address</p>

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <p class="small text-dark mb-1 fw-bold">Sipariş Notu:</p>
                        <p class="small text-muted italic">"@Model.Description"</p>
                    }

                    <hr />
                    <div class="d-flex justify-content-between small mb-1">
                        <span>Sipariş Tarihi:</span>
                        <span class="fw-bold">@Model.CreatedDate.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 bg-light">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3">Ödeme Özeti</h6>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Ara Toplam</span>
                        <span>@Model.TotalBasePrice.ToString("C2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 text-success">
                        <span>İndirim Miktarı</span>
                        <span class="fw-bold">@Model.DiscountAmount.ToString("C2")</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="h6 mb-0 fw-bold">Toplam</span>
                        <span class="h4 mb-0 fw-bold text-ty-orange">@Model.FinalTotalPrice.ToString("C2")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="invoiceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title">Sipariş Faturası</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4" id="invoiceContainer">
                <div class="row mb-4">
                    <div class="col-6">
                        <h4 class="text-dark">ByteMarket</h4>
                        <p class="small text-muted">@Model.Address</p>
                    </div>
                    <div class="col-6 text-end">
                        <h6>Fatura Tarihi: @Model.CreatedDate.ToString("dd.MM.yyyy")</h6>
                        <h6>Sipariş No: #<strong>@Model.OrderCode</strong></h6>
                    </div>
                </div>

                <table class="table table-borderless">
                    <thead class="table-light">
                        <tr>
                            <th>Ürün</th>
                            <th class="text-center">Adet</th>
                            <th class="text-end">Fiyat</th>
                            <th class="text-end">Toplam</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.BasketItems)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">@item.Price.ToString("C2")</td>
                                <td class="text-end">@((item.Price * item.Quantity).ToString("C2"))</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <hr />

                <div class="row justify-content-end">
                    <div class="col-5">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Ara Toplam:</span>
                            <span>@Model.TotalBasePrice.ToString("C2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 text-danger">
                            <span>İndirim:</span>
                            <span>-@Model.DiscountAmount.ToString("C2")</span>
                        </div>
                        <div class="d-flex justify-content-between border-top pt-2 fw-bold">
                            <span>Genel Toplam:</span>
                            <span class="text-primary">@Model.FinalTotalPrice.ToString("C2")</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 d-flex gap-2">
                <button type="button" id="btnDownloadPdf" class="btn btn-danger flex-grow-1 py-2">
                    <i class="fa fa-file-pdf me-2"></i>PDF Olarak İndir
                </button>
                <button type="button" id="btnSendInvoice" class="btn btn-success flex-grow-1 py-2" data-orderid="@Model.Id">
                    <i class="fa fa-paper-plane me-2"></i>Mesaj Gönder
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="productReviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header border-0">
                <h5 class="modal-title">Ürünü Değerlendir</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body p-4">

                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="rounded border p-1" style="width: 80px; height: 80px;">
                        <img src="" class="img-fluid object-fit-contain h-100 w-100" id="productImage" 
                             alt="" onerror="this.src='@noImageUrl'">
                    </div>
                    <h6 class="mb-1 fw-bold text-dark" id="productName"></h6>
                </div>
               

                <form id="productReviewForm">
                    <input type="hidden" id="orderId" name="order_id" />
                    <input type="hidden" id="productId" name="product_id" />

                    <div class="mb-3">
                        <label class="form-label d-block">Puanınız:</label>
                        <div class="star-rating">
                            <input type="radio" name="rating" value="5" id="5"><label for="5">☆</label>
                            <input type="radio" name="rating" value="4" id="4"><label for="4">☆</label>
                            <input type="radio" name="rating" value="3" id="3"><label for="3">☆</label>
                            <input type="radio" name="rating" value="2" id="2"><label for="2">☆</label>
                            <input type="radio" name="rating" value="1" id="1"><label for="1">☆</label>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label for="comment">Yorumunuz</label>
                        <textarea class="form-control" id="comment" rows="4" placeholder="Ürün hakkındaki deneyimlerinizi paylaşın..."></textarea>
                    </div>
                </form>
                <div id="responseMessage" class="mt-3"></div>
            </div>
            <div class="modal-footer border-0 d-flex gap-2">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Vazgeç</button>
                <button type="submit" form="productReviewForm" id="btnSubmit" class="btn btn-ty-orange text-white">
                    Değerlendirmeyi Gönder
                </button>

            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editReviewModal" tabindex="-1" aria-labelledby="editReviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold" id="editReviewModalLabel">Yorumu Düzenle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">

                <div id="editModelResponseMessage" class="my-3"></div>

                <form id="editReviewForm">
                    <input type="hidden" id="editReviewId" />

                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="rounded border p-1" style="width: 80px; height: 80px;">
                            <img src="" class="img-fluid object-fit-contain h-100 w-100" id="editProductImage"
                                 alt="" onerror="this.src='@noImageUrl'">
                        </div>
                        <h6 class="mb-1 fw-bold text-dark" id="editProductName"></h6>
                    </div>

                    <div class="mb-3">
                        <label class="form-label d-block fw-medium">Puanınız:</label>
                        <div class="star-rating edit-stars">
                            <input type="radio" name="editRating" value="5" id="edit-5"><label for="edit-5">☆</label>
                            <input type="radio" name="editRating" value="4" id="edit-4"><label for="edit-4">☆</label>
                            <input type="radio" name="editRating" value="3" id="edit-3"><label for="edit-3">☆</label>
                            <input type="radio" name="editRating" value="2" id="edit-2"><label for="edit-2">☆</label>
                            <input type="radio" name="editRating" value="1" id="edit-1"><label for="edit-1">☆</label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="editComment" class="form-label fw-medium">Yorumunuz:</label>
                        <textarea class="form-control" id="editComment" rows="4" placeholder="Deneyiminizi güncelleyin..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Vazgeç</button>
                <button type="submit" form="editReviewForm" id="btnUpdateReview" class="btn btn-ty-orange text-white px-4">Değişiklikleri Kaydet</button>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-light {
        background-color: #f8f9fa !important;
    }

    .object-fit-contain {
        object-fit: contain;
    }

    .star-rating {
        display: flex;
        flex-direction: row-reverse;
        justify-content: flex-end;
    }

        .star-rating input {
            display: none;
        }

        .star-rating label {
            font-size: 30px;
            color: #ddd;
            cursor: pointer;
        }

        .star-rating input:checked ~ label {
            color: #f5b301;
        }

        .star-rating label:hover, .star-rating label:hover ~ label {
            color: #f5b301;
        }
</style>

@section Scripts {
    <script src="~/js/customer/order/order-detail.js" asp-append-version="false"></script>
    <script src="~/js/customer/order/order-success.js" asp-append-version="false"></script>
}