@model ByteMarket.WebUI.Models.Order.SingleOrderViewModel

@Html.AntiForgeryToken();

<div class="success-order text-center gap-2 my-5">
    <div class="d-flex flex-column align-items-center justify-content-center">
        <i class="fa fa-check-circle text-success" style="font-size: 5rem;"></i>
        <h2 class="mt-3">Siparişiniz Başarıyla Alındı!</h2>
        <p class="text-muted">Sipariş Kodunuz: <strong>@Model.OrderCode</strong></p>
    </div>

    <div class="mt-4">
        <button type="button" class="btn btn-outline-dark me-2" data-bs-toggle="modal" data-bs-target="#invoiceModal">
            <i class="fa fa-file-invoice"></i> Faturayı Görüntüle
        </button>
        <a href="/" class="btn btn-primary">Ürünlere Göz At</a>
    </div>
</div>

<div class="modal fade" id="invoiceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title">Sipariş Detayı</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4" id="invoiceContainer">
                <div class="row mb-4">
                    <div class="col-6">
                        <h4 class="text-dark">ByteMarket</h4>
                        <p class="small text-muted">@Model.Address</p>
                    </div>
                    <div class="col-6 text-end">
                        <h6>Fatura Tarihi: @Model.CreatedDate.ToString("dd.MM.yyyy")</h6>
                        <h6>Sipariş No: #@Model.OrderCode</h6>
                    </div>
                </div>

                <table class="table table-borderless">
                    <thead class="table-light">
                        <tr>
                            <th>Ürün</th>
                            <th class="text-center">Adet</th>
                            <th class="text-end">Fiyat</th>
                            <th class="text-end">Toplam</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.BasketItems)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">@item.Price.ToString("C2")</td>
                                <td class="text-end">@((item.Price * item.Quantity).ToString("C2"))</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <hr />

                <div class="row justify-content-end">
                    <div class="col-5">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Ara Toplam:</span>
                            <span>@Model.TotalBasePrice.ToString("C2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 text-danger">
                            <span>İndirim:</span>
                            <span>-@Model.DiscountAmount.ToString("C2")</span>
                        </div>
                        <div class="d-flex justify-content-between border-top pt-2 fw-bold">
                            <span>Genel Toplam:</span>
                            <span class="text-primary">@Model.FinalTotalPrice.ToString("C2")</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" id="btnSendInvoice" class="btn btn-success w-100 py-2" data-orderid="@Model.Id">
                    <i class="fa fa-paper-plane me-2"></i>Faturamı Mesaj Olarak Gönder
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts{

    <script src="~/js/customer/order/order-success.js" asp-append-version="false"></script>
}