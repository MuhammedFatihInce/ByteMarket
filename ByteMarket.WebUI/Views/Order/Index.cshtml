@model List<ByteMarket.WebUI.Models.Order.OrderListDetailViewModel>

@{
    ViewData["Title"] = "Siparişlerim";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fa fa-box-open text-ty-orange me-2"></i> @ViewData["Title"]</h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Anasayfa</a></li>
                <li class="breadcrumb-item active">Siparişlerim</li>
            </ol>
        </nav>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4 py-3">Sipariş Kodu</th>
                                <th>Tarih</th>
                                <th>Müşteri</th>
                                <th>Toplam Tutar</th>
                                <th>Durum</th>
                                <th class="text-center pe-4">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-primary">#@order.OrderCode</td>
                                    <td>@order.CreatedDate.ToString("dd MMM yyyy HH:mm")</td>
                                    <td>@order.UserName</td>
                                    <td class="fw-bold text-ty-orange">@order.TotalPrice.ToString("C2")</td>
                                    <td>
                                        <span class="badge rounded-pill text-success border border-success px-3 py-2" style=" background-color: #e8f5e9">
                                            Tamamlandı
                                        </span>
                                    </td>
                                    <td class="text-center pe-4">
                                        <a asp-action="Detail" asp-route-id="@order.Id" class="btn btn-outline-dark btn-sm rounded-pill px-3 shadow-none">
                                            Detayları Gör
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 shadow-sm rounded-4 bg-white border">
            <i class="fa fa-receipt fa-4x text-muted mb-3 opacity-25"></i>
            <h4 class="text-muted">Henüz hiç siparişiniz bulunmuyor.</h4>
            <a href="/" class="btn btn-ty-orange text-white mt-3 px-4 py-2 rounded-pill">
                Alışverişe Başla
            </a>
        </div>
    }
</div>

<style>
    .table thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #6c757d;
        border-top: none;
    }

    .table tbody tr {
        transition: all 0.2s;
    }

        .table tbody tr:hover {
            background-color: #fffaf7 !important;
        }
</style>