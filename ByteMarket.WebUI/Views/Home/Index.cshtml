@model List<ByteMarket.WebUI.Models.Product.ProductListViewModel>

@{
    var categoryId = ViewBag.ActiveCategoryId as string;
    ViewData["Title"] = string.IsNullOrEmpty(categoryId) ? "Tüm Ürünler" : "Kategori Ürünleri";
}

@await Component.InvokeAsync("CategoryNav")

<div class="container mt-5">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h3 class="fw-bold mb-0 text-dark">
            <i class="bi bi-stars text-ty-orange me-2"></i>@ViewData["Title"]
        </h3>
        <span class="badge bg-light text-dark border p-2">Toplam @Model.Count Ürün</span>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var product in Model)
        {
            <div class="col">
                @await Html.PartialAsync("~/Views/Shared/Partials/_ProductCardPartial.cshtml", product)
            </div>
        }
    </div>
</div>

@section Scripts{
    <script src="~/js/customer/wishList/wishList-add.js" asp-append-version="false"></script>
    <script src="~/js/customer/basket/basket-add.js" asp-append-version="false"></script>
}