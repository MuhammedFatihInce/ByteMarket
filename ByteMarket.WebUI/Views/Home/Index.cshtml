@using ByteMarket.WebUI.Models.ProductViewModels
@model List<ProductListViewModel>
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration

@{
    ViewData["Title"] = "Ürün Listesi";
}

<div class="container mt-5">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h3 class="fw-bold mb-0 text-dark">
            <i class="bi bi-stars text-ty-orange me-2"></i>Tüm Ürünler
        </h3>
        <span class="badge bg-light text-dark border p-2">Toplam @Model.Count Ürün</span>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var product in Model)
        {
            <div class="col">
                @await Html.PartialAsync("~/Views/Shared/Partials/_ProductCardPartial.cshtml", product)
            </div>
        }
    </div>
</div>