@model ByteMarket.WebUI.Models.Basket.ListBasketViewModel
@inject IConfiguration Configuration

@{
    ViewData["Title"] = "Alışveriş Sepetim";

    var apiBaseUrl = Configuration["ApiSettings:BaseStorageAdress"];
    string noImageUrl = "https://placehold.co/600x400?text=Resim+Yok";
}

<div class="container mt-5">
    @Html.AntiForgeryToken()
    <h2><i class="fa fa-shopping-cart"></i> @ViewData["Title"]</h2>
    <hr />


    @if (Model.BasketItem != null && Model.BasketItem.Any())
    {

        <div class="row">
            <div class="col-md-7">
                <div class="shadow-sm mt-4" style="border: 1px solid rgba(242, 122, 26, 0.1);">
                    <div class="table-responsive">
                        <table class="table table-borderless table-hover align-middle mb-0">
                            <thead class="bg-light" style="border-bottom: 2px solid #f8f9fa;">
                                <tr>
                                    <th class="py-3 px-4 text-muted fw-normal" style="font-size: 0.9rem;">Ürün Detayları (@Model.BasketItem.Sum(x => x.Quantity) Ürün)</th>
                                    <th class="py-3 text-center text-muted fw-normal" style="font-size: 0.9rem; width: 150px;">Adet</th>
                                    <th class="py-3 px-4 text-end text-muted fw-normal" style="font-size: 0.9rem; width: 120px;">Fiyat</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.BasketItem)
                                {
                                    var currentImagePath = !string.IsNullOrEmpty(item.ImagePath)
                                    ? $"{apiBaseUrl}{item.ImagePath.Replace("\\", "/")}"
                                    : noImageUrl;

                                    <tr class="border-bottom">
                                        <td class="p-4">
                                            <a asp-controller="Product" asp-action="Detail" asp-route-id="@item.ProductId" class="text-decoration-none text-dark">
                                                <div class="d-flex align-items-center gap-3">
                                                    <div class="border rounded bg-white p-1 shadow-sm" style="width: 64px; height: 64px; flex-shrink: 0;">
                                                        <img src="@currentImagePath"
                                                             class="img-fluid object-fit-contain h-100 w-100"
                                                             alt="@item.ProductName"
                                                             onerror="this.src='@noImageUrl'">
                                                    </div>
                                                    <span class="fw-semibold" style="font-size: 0.95rem;">@item.ProductName</span>
                                                </div>
                                            </a>
                                        </td>

                                        <td class="text-center">
                                            <div class="input-group input-group-sm align-items-center bg-white rounded-pill p-1 mx-auto shadow-sm" style="border: 1px solid #eee; width: 100px;">
                                                <button class="btn btn-white rounded-circle border-0 shadow-none px-2 text-muted"
                                                        type="button"
                                                        onclick="changeQuantity('@item.BasketItemId', -1)">
                                                    <i class="fa fa-minus" style="font-size: 0.75rem;"></i>
                                                </button>

                                                <input type="text"
                                                       id="qty-@item.BasketItemId"
                                                       class="form-control border-0 text-center fw-bold shadow-none p-0"
                                                       style="background: #fff0e4; color: #f27a1a; border-radius: 50%; width: 26px; height: 26px; pointer-events: none; font-size: 0.85rem;"
                                                       value="@item.Quantity" readonly>

                                                <button class="btn btn-white rounded-circle border-0 shadow-none px-2"
                                                        type="button"
                                                        onclick="changeQuantity('@item.BasketItemId', 1)">
                                                    <i class="fa fa-plus text-ty-orange" style="font-size: 0.75rem;"></i>
                                                </button>
                                            </div>
                                        </td>

                                        <td class="p-4 text-end">
                                            <div class="d-flex flex-column justify-content-center align-items-end h-100">
                                                <span class="text-ty-orange fw-bold fs-6 mb-2">
                                                    @item.Price.ToString("C2")
                                                </span>
                                                <a href="javascript:void(0)" class="delete-basket-item text-muted text-decoration-none d-flex align-items-center gap-1 hover-danger"
                                                   data-basketItemId="@item.BasketItemId">
                                                    <i class="fa fa-trash-alt" style="font-size: 0.85rem;"></i>
                                                    <span style="font-size: 0.8rem;">Sil</span>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 24px; z-index: 1000;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Sepet Özeti</h5>
                        
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Ürün Toplamı</span>
                            <span class="fw-bold">@Model.BasketItem.Sum(x => x.Total).ToString("C2")</span>
                        </div>
                        
                        <div class="d-flex justify-content-between mb-3 text-success">
                            <span>Kargo Toplam</span>
                            <span class="fw-bold">Bedava</span>
                        </div>
                        
                        <hr />
                        
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <span class="h6 mb-0">Toplam</span>
                            <span class="h4 mb-0 fw-bold text-ty-orange">@Model.BasketItem.Sum(x => x.Total).ToString("C2")</span>
                        </div>
                        
                        <button class="btn btn-ty-orange text-white w-100 py-3 rounded-3 fw-bold shadow-sm"
                                data-bs-toggle="modal" 
                                data-bs-target="#checkoutModal">
                            Sepeti Onayla
                        </button>
                        
                        <div class="mt-3 p-2 text-center shadow-sm border rounded-pill">
                            <a href="/" class="text-decoration-none small text-dark">
                                <i class="fa fa-arrow-left me-1"></i> Alışverişe Devam Et
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="empty-list-warning align-content-center gap-2">
            <div d-flex align-items-center justify-content-center>
                <i class="fa fa-exclamation-triangle"></i>
                <span>Sepetinizde ürün bulunmamaktadır.</span>
            </div>
            <a href="/" class="btn btn-ty-orange text-white mt-3">Ürünlere Göz At</a>
        </div>
    }
</div>


<div class="modal fade" id="checkoutModal" tabindex="-1" aria-labelledby="checkoutModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-bottom-0 p-4">
                <h5 class="modal-title fw-bold" id="checkoutModalLabel">Ödeme Bilgileri</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 pt-0">
                <form id="paymentForm">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Kart Üzerindeki İsim</label>
                        <input type="text" class="form-control rounded-3" id="cardName" placeholder="Ad Soyad" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Kart Numarası</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fa fa-credit-card text-muted"></i></span>
                            <input type="text" class="form-control border-start-0 rounded-end-3" id="cardNumber" placeholder="0000 0000 0000 0000" maxlength="19" required>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-7 mb-3">
                            <label class="form-label small fw-bold text-muted">Son Kullanma Tarihi</label>
                            <input type="text" class="form-control rounded-3" id="cardExpiry" placeholder="AA/YY" maxlength="5" required>
                        </div>
                        <div class="col-md-5 mb-3">
                            <label class="form-label small fw-bold text-muted">CVC</label>
                            <input type="password" class="form-control rounded-3" id="cardCvc" placeholder="123" maxlength="3" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Adress Bilgisi</label>
                        <input type="text" class="form-control rounded-3" id="adress" placeholder="Adress" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Açıklama</label>
                        <input type="text" class="form-control rounded-3" id="description" placeholder="Açıklama" required>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-ty-orange text-white w-100 py-3 rounded-3 fw-bold shadow-sm"
                        data-basketId="@Model.Id">
                            Ödemeyi Tamamla (@Model?.BasketItem?.Sum(x => x.Total).ToString("C2"))
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="~/js/customer/basket/basket-list.js" asp-append-version="false"></script>
}

