@using Microsoft.AspNetCore.Mvc.TagHelpers
@model ByteMarket.WebUI.Models.CategoryViewModels.CreateCategoryViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h4 class="mb-0 fw-bold text-ty-orange">
                        <i class="bi bi-plus-circle me-2"></i>Yeni Kategori Ekle
                    </h4>
                </div>
                <div class="card-body p-4">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-semibold">Kategori Adı</label>
                            <input asp-for="Name" class="form-control bg-light border-0 shadow-none py-2" placeholder="Örn: Mobilya">
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Icon" class="form-label fw-semibold">İkon Class (Bootstrap Icons)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0">
                                    <i id="iconPreview" class="bi bi-tag text-ty-orange"></i>
                                </span>
                                <input asp-for="Icon" class="form-control bg-light border-0 shadow-none py-2" 
                                       id="categoryIconInput" placeholder="Örn: bi-tv">
                            </div>
                            <span asp-validation-for="Icon" class="text-danger small"></span>
                        </div>


                        <div class="d-grid mt-3">
                            <button type="submit" class="btn btn-primary py-2 fw-bold bg-ty-orange border-0 shadow-sm text-white">
                                Kategori Ekle
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/admin/category/category-icon-preview.js" asp-append-version="true"></script>
}