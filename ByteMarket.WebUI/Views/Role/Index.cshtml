@using ByteMarket.WebUI.Models.Role
@model List<RoleListViewModel>
@{
    ViewData["Title"] = "Rol Yönetimi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-shield-check me-2"></i>Rol Yönetimi</h2>
    </div>

    <div class="card border-0 shadow-sm p-4 mb-4">
        <form asp-action="Create" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <div class="col-md-8">
                <input type="text" name="roleName" class="form-control" placeholder="Yeni rol ismi (Örn: Editor, Moderator)" required>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary bg-ty-orange border-0 w-100 fw-bold">
                    <i class="bi bi-plus-lg me-1"></i> Rol Ekle
                </button>
            </div>
        </form>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                <tr>
                    <th class="ps-4">Rol İsmi</th>
                    <th class="text-end pe-4">İşlemler</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var role in Model)
                {
                    <tr>
                        <td class="ps-4 fw-semibold">@role.Name</td>
                        <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-danger border-0" onclick="deleteRole('@role.Id', '@role.Name')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
          function deleteRole(id, roleName) {
            Alert.fire({
                title: `${roleName} rolünü silmek istiyor musunuz?`,
                text: "Bu işlem geri alınamaz ve bu role sahip kullanıcıların yetkileri etkilenebilir!",
                icon: 'warning',
                confirmButtonText: 'Evet, Sil',
                onConfirm: async () => {

                    const response = await CustomAjax.delete(`/Role/Delete/${id}`);
                    if (response && response.success) {
                        location.reload();
                    }
                },
                successMessage: 'Rol başarıyla silindi!'
            });
        }
    </script>
}