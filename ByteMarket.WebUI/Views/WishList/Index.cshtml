@model List<ByteMarket.WebUI.Models.wishList.WishListProductViewModel>

@{
    ViewData["Title"] = "Favorilerim";
}

<div class="container mt-5">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h3 class="fw-bold mb-0 text-dark">
            <i class="bi bi-heart-fill text-ty-orange me-2"></i>@ViewData["Title"]
        </h3>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var product in Model)
            {
                <div class="col">
                    @await Html.PartialAsync("~/Views/Shared/Partials/_WishListProductCardPartial.cshtml", product)
                </div>
            }
            
            </div>
    }
    else
    {
        <div class="empty-list-warning align-content-center gap-2">
            <div d-flex align-items-center justify-content-center>
                <i class="fa fa-exclamation-triangle"></i>
                <span>İstek listesi boş.</span>
            </div>
            <a href="/" class="btn btn-ty-orange text-white mt-3">Ürünlere Göz At</a>
        </div>
    }

</div>

@section Scripts {
    <script src="~/js/customer/wishList/wishList-delete.js" asp-append-version="false"></script>
    <script src="~/js/customer/basket/basket-add.js" asp-append-version="false"></script>
}