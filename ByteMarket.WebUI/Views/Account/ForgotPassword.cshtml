@model ByteMarket.WebUI.Models.Auth.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Şifremi Unuttum";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg rounded-4 p-4">
                <div class="text-center mb-4">
                    <h3 class="fw-bold">Şifremi Unuttum</h3>
                    <p class="text-muted small">Sistemde kayıtlı e-posta adresinizi girdiğinizde size bir sıfırlama linki göndereceğiz.</p>
                </div>

                <form id="forgotPasswordForm">
                    @Html.AntiForgeryToken()
                    <div class="mb-4">
                        <label class="form-label fw-semibold">E-Posta Adresiniz</label>
                        <input asp-for="Email" class="form-control form-control-lg border-2 shadow-none" placeholder="ornek@mail.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-ty-orange text-white w-100 py-3 fw-bold fs-5 shadow-sm">
                        <i class="bi bi-send-fill me-2"></i>SIFIRLAMA LİNKİ GÖNDER
                    </button>
                </form>

                <div class="text-center mt-4">
                    <a asp-action="Login" class="text-decoration-none text-ty-orange small fw-bold">Giriş Sayfasına Dön</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/customer/auth/forgot-password.js" asp-append-version="true"></script>
}