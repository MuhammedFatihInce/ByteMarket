@model ByteMarket.WebUI.Models.Auth.LoginViewModel
@inject IConfiguration Configuration

@{
 
    ViewData["Title"] = "Giriş Yap";
    var googleClientId = Configuration["ExternalLogin:Google:ClientId"];
}

<script src="https://accounts.google.com/gsi/client" async defer></script>

<div class="account-container">
    <div class="account-card shadow-lg">
        <div class="text-center">
            <h2 class="fw-bold">ByteMarket<span class="text-ty-orange">.</span></h2>
            <p class="text-muted">Hoş geldiniz, lütfen bilgilerinizi giriniz.</p>
        </div>

        <form asp-action="Login" method="post" class="mt-4">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="form-floating mb-3">
                <input asp-for="UsernameOrEmail" class="form-control custom-input" placeholder="E-posta veya Kullanıcı Adı">
                <label asp-for="UsernameOrEmail">E-posta veya Kullanıcı Adı</label>
                <span asp-validation-for="UsernameOrEmail" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Password" type="password" class="form-control custom-input" placeholder="Şifre">
                <label asp-for="Password">Şifre</label>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" type="checkbox">
                    <label class="form-check-label small text-muted" asp-for="RememberMe">Beni Hatırla</label>
                </div>
                <a href="#" class="text-ty-orange text-decoration-none small fw-bold">Şifremi Unuttum</a>
            </div>

            <button type="submit" class="btn btn-account w-100 py-3 fw-bold shadow-sm">
                GİRİŞ YAP
            </button>
        </form>

        <div class="text-center my-4">
            <div class="position-relative">
                <hr>
                <span class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted small">VEYA</span>
            </div>
        </div>

        <div id="g_id_onload"
             data-client_id="@googleClientId"
             data-callback="handleCredentialResponse"
             data-auto_prompt="false">
        </div>
        
        <div class="g_id_signin w-100"
             data-type="standard"
             data-size="large"
             data-theme="outline"
             data-text="signin_with"
             data-shape="rectangular"
             data-logo_alignment="left">
        </div>

        <div class="text-center mt-4">
            <p class="small text-muted">Henüz üye değil misiniz? <a asp-action="Register" class="text-ty-orange fw-bold text-decoration-none">Ücretsiz Kayıt Ol</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/customer/auth/google-login.js" asp-append-version="true"></script>

}