@model ByteMarket.WebUI.Models.Auth.ResetPasswordViewModel
@{
    ViewData["Title"] = "Yeni Şifre Belirle";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg rounded-4 p-4">
                <div class="text-center mb-4">
                    <h3 class="fw-bold text-dark">Yeni Şifre Belirle</h3>
                    <p class="text-muted small">Güvenliğiniz için güçlü bir şifre seçiniz.</p>
                </div>

                <form id="resetPasswordForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="Token" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Yeni Şifre</label>
                        <input asp-for="Password" type="password" class="form-control border-2 shadow-none" placeholder="******" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Şifre Tekrar</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control border-2 shadow-none" placeholder="******" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-ty-orange text-white w-100 py-3 fw-bold fs-5 shadow-sm">
                        <i class="bi bi-check-circle-fill me-2"></i>ŞİFREYİ GÜNCELLE
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>


@section Scripts{
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/customer/auth/reset-password.js" asp-append-version="true"></script>
}