@using ByteMarket.WebUI.Areas.Admin.Models.Role
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model List<ByteMarket.WebUI.Areas.Admin.Models.User.UserListViewModel>

@{
    var roles = ViewBag.AllRoles as List<RoleListViewModel>;
}

<div class="container-fluid pt-4 px-4">
    @Html.AntiForgeryToken()

    <div class="bg-white rounded shadow-sm p-4">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-people-fill me-2 text-ty-orange"></i>Kullanıcı ve Yetki Yönetimi</h5>
                <small class="text-muted">Sistemdeki kullanıcıların rollerini buradan düzenleyebilirsiniz.</small>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table align-middle table-hover border-top">
                <thead>
                    <tr class="text-secondary small text-uppercase" style="background-color: #fafafa;">
                        <th class="py-3 ps-3">Kullanıcı Bilgisi</th>
                        <th class="py-3">Kullanıcı Adı</th>
                        <th class="py-3">E-Posta</th>
                        <th class="py-3">Mevcut Roller</th>
                        <th class="py-3 text-end pe-3">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr id="user-row-@user.Id">
                            <td class="ps-3">
                                <div class="fw-bold text-dark">@user.NameSurname</div>
                                <small class="text-muted" style="font-size: 11px;">ID: @user.Id</small>
                            </td>
                            <td>@user.UserName</td>
                            <td>@user.Email</td>
                            <td>
                                @foreach (var role in user.Roles)
                                {
                                    <span class="badge @(role == "Admin" ? "bg-danger" : "bg-primary") bg-opacity-10 @(role == "Admin" ? "text-danger" : "text-primary") border @(role == "Admin" ? "border-danger" : "border-primary") border-opacity-25 px-2 py-1 me-1">
                                        @role
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-3">
                                <button class="btn btn-sm btn-ty-orange text-white fw-bold px-3 btn-manage-role"
                                        data-id="@user.Id"
                                        data-username="@user.UserName"
                                        data-current-roles="@string.Join(",", user.Roles)">
                                    <i class="bi bi-shield-lock me-1"></i> Yetki Yönet
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="assignRoleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-light border-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-person-badge me-2"></i>Rolleri Düzenle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <p class="text-muted small mb-3"><strong id="modalUserName" class="text-dark"></strong> kullanıcısı için yetki seviyelerini seçiniz.</p>
                <input type="hidden" id="modalUserId" />

                <div id="rolesListContainer">
                    @foreach (var role in roles)
                    {
                        <div class="d-flex align-items-center mb-3 p-3 border rounded transition" style="min-height: 60px;">
                            <div class="form-check form-switch m-0 p-0 d-flex align-items-center w-100">
                                <input class="form-check-input role-checkbox ms-0" type="checkbox"
                                       id="role_@role.Id" value="@role.Name" style="cursor:pointer; width: 2.5em; height: 1.25em; float: none;">
                                <label class="form-check-label fw-semibold ms-3 mb-0" for="role_@role.Id" style="cursor:pointer; flex-grow: 1;">
                                    @role.Name
                                </label>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light fw-bold" data-bs-dismiss="modal">Vazgeç</button>
                <button type="button" id="btnSaveRoles" class="btn btn-ty-orange text-white fw-bold px-4">Değişiklikleri Kaydet</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin/user/user-list.js" asp-append-version="true"></script>
}